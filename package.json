{
  "name": "electrogram",
  "version": "0.1.2",
  "description": "Accessible Electron Telegram client",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:safe": "electron-vite dev -- --disable-gpu --no-sandbox",
    "build": "electron-vite build",
    "predist": "npm run build",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "postinstall": ""
  },
  "dependencies": {
    "telegram": "^2.26.16"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "telegram",
    "electron",
    "accessible",
    "a11y"
  ],
  "author": "",
  "license": "MIT"
}
